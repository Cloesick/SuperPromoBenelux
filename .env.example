# Affiliate links — set these to your affiliate tracking URLs.
# When set, they override the default direct links to retailer websites.
# Example: AFFILIATE_AH=https://tc.tradetracker.net/?c=12345&m=67890&a=111111&r=&u=https%3A%2F%2Fwww.ah.be%2Fbonus

AFFILIATE_AH=
AFFILIATE_LIDL=
AFFILIATE_DELHAIZE=
AFFILIATE_COLRUYT=
AFFILIATE_ALDI=
AFFILIATE_ACTION=

# Microsoft Clarity — behavior analytics (heatmaps, session recordings)
# Get your project ID from https://clarity.microsoft.com/
# Only loaded after user accepts cookies (GDPR compliant)
NEXT_PUBLIC_CLARITY_ID=

# Vercel Analytics + Speed Insights are enabled automatically (no config needed)
# They are cookie-less and privacy-friendly — no consent required
